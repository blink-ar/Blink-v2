{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/[...path].js": {
      "includeFiles": "dist/index.html"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path]?path=$1"
    },
    {
      "src": "/business/([^/]+)",
      "dest": "/api/[...path]?path=business/$1"
    },
    {
      "src": "/comercios/([^/]+)",
      "dest": "/api/[...path]?path=comercios/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
