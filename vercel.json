{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/[...path].js": {
      "includeFiles": "dist/index.html"
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "blinkapp.com.ar"
        }
      ],
      "destination": "https://www.blinkapp.com.ar/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/profile",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/profile/",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/saved",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/saved/",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path]?path=$1"
    },
    {
      "src": "/business/([^/]+)",
      "dest": "/api/[...path]?path=business/$1"
    },
    {
      "src": "/categorias/([^/]+)/page/([0-9]+)",
      "dest": "/api/[...path]?path=categorias/$1/page/$2"
    },
    {
      "src": "/categorias/([^/]+)",
      "dest": "/api/[...path]?path=categorias/$1"
    },
    {
      "src": "/descuentos/([^/]+)/([^/]+)/([^/]+)",
      "dest": "/api/[...path]?path=descuentos/$1/$2/$3"
    },
    {
      "src": "/descuentos/([^/]+)/([^/]+)",
      "dest": "/api/[...path]?path=descuentos/$1/$2"
    },
    {
      "src": "/comercios/([^/]+)",
      "dest": "/api/[...path]?path=comercios/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(?:.*\\.(?:txt|md|ya?ml)|okf(?:/.*)?)",
      "dest": "/api/[...path]?path=__not_found"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
