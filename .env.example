VITE_SITE_URL=https://www.example.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Optional local Vite proxy target for /api/* (use with `vercel dev` default port)
VITE_API_BASE_URL=http://localhost:3000
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key
GOOGLE_MAPS_API_KEY=your_google_maps_key
MONGODB_URI_READ_ONLY=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
# Write-capable URI for user accounts (must have insert/update on 'users' collection)
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
# Secret for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=changeme-replace-with-a-random-secret
# Public URL of the app (used for OAuth redirect URIs)
APP_URL=https://yourapp.vercel.app
# Google OAuth — create at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook OAuth — create at developers.facebook.com
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
DATABASE_NAME=benefitsV3
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX=search_entities_v1
SEARCH_DEBUG=false
SEARCH_SOURCE_COLLECTION=confirmed_benefits
SEARCH_LOCAL_DISTANCE_RADIUS_KM=80
SEARCH_DISTANT_RESULT_CUTOFF_KM=120
SEARCH_MIN_NEARBY_RESULTS_FOR_DISTANCE_PRUNING=3
