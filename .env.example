VITE_SITE_URL=https://www.example.com
# Push notifications — run `node scripts/generate-vapid-keys.mjs` to generate
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com
# Secret to protect POST /api/notifications/send (required in production)
NOTIFICATIONS_SECRET=
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Auth0 — create app at auth0.com (Single Page Application)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
# Optional local Vite proxy target for /api/* (use with `vercel dev` default port)
VITE_API_BASE_URL=http://localhost:3000
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key
GOOGLE_MAPS_API_KEY=your_google_maps_key
# Server-only MongoDB URIs. Never prefix these with VITE_.
MONGODB_URI_READ_ONLY=mongodb+srv://<read-user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
# Required in production. Use least-privilege write access, not admin credentials.
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
DATABASE_NAME=benefitsV3
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX=search_entities_v1
SEARCH_DEBUG=false
SEARCH_SOURCE_COLLECTION=confirmed_benefits
SEARCH_LOCAL_DISTANCE_RADIUS_KM=80
SEARCH_DISTANT_RESULT_CUTOFF_KM=120
SEARCH_MIN_NEARBY_RESULTS_FOR_DISTANCE_PRUNING=3
